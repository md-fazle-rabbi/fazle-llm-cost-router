# ============================================================
# fazle-llm-cost-router — Environment Variables Template
# Copy to .env and fill in real values
# ============================================================

APP_ENV=development
APP_VERSION=1.0.0

GEMINI_API_KEY=AIza-your-key-here
CHEAP_MODEL=gemini/gemini-3.1-flash-lite
EXPENSIVE_MODEL=gemini/gemini-2.5-flash

COMPLEXITY_THRESHOLD=0.5
MAX_TOKENS_CHEAP=150
MAX_TOKENS_EXPENSIVE=1024
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROJECT_ID=your-project-id